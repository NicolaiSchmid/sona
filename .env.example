# Sona environment example — copy to .env and fill in locally.
# NEVER commit real values. .env is gitignored.

# --- Enable Banking (AIS, read-only) ---------------------------------------
# Application ID from the Enable Banking control panel.
ENABLE_BANKING_APP_ID=
# Path to the RSA private key PEM that pairs with the application's public key.
# Keep this file outside the repo; *.pem/*.key are gitignored as a backstop.
ENABLE_BANKING_PRIVATE_KEY_PATH=
# API base. Sandbox and production share this host; the app registration differs.
ENABLE_BANKING_API_BASE=https://api.enablebanking.com
# Redirect URL registered for the application's AIS authorization flow.
ENABLE_BANKING_REDIRECT_URL=
